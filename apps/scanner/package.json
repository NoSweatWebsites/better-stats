{
  "name": "@betterstats/scanner",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --out-dir dist --no-splitting --external drizzle-orm --external postgres --external @anthropic-ai/sdk --external openai --external @google/generative-ai --external @hono/node-server --external hono",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@betterstats/db": "workspace:*",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.20",
    "openai": "^4.77.3"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/node": "^22.10.5",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
