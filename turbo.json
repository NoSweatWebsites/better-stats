{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "target/release/**"]
    },
    "build:api": {
      "cache": true,
      "outputs": ["target/release/api"]
    },
    "build:worker": {
      "cache": true,
      "outputs": ["target/release/worker"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": { "outputs": [] },
    "test": { "dependsOn": ["^build"], "outputs": [] },
    "type-check": { "dependsOn": ["^build"], "outputs": [] }
  }
}
