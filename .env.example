# Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/betterstats

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=betterstats

# Redis
REDIS_URL=redis://localhost:6379

# Clerk
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json

# Google OAuth (shared client for GA4 + GSC)
GOOGLE_OAUTH_CLIENT_ID=...
GOOGLE_OAUTH_CLIENT_SECRET=...
GA4_REDIRECT_URL=https://api.betterstats.io/api/callbacks/ga4
GSC_REDIRECT_URL=https://api.betterstats.io/api/callbacks/gsc

# Token encryption (32 bytes, base64 encoded — run: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=...

# Resend
RESEND_API_KEY=re_...

# Sentry
SENTRY_DSN=https://...

# App
APP_ENV=development
API_PORT=8080

